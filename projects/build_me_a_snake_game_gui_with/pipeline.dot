
digraph generate_app {
    rankdir=LR;
    goal="Generate an application based on user request: Build me a snake game GUI with good graphics";

    Start [shape=Mdiamond, label="Start"];
    
    Generate [shape=box, label="Generate Code", 
              type="codergen",
              prompt="User requested to build: Build me a snake game GUI with good graphics. Please provide the complete Python code for this application. Output only the code, wrapped in ```python ... ```."];
              
    Review [shape=hexagon, label="Human Review",
            type="wait.human",
            prompt="Review the generated code:\n\n${Generate.output}"];
          
    Done [shape=Msquare, label="Done"];

    Start -> Generate;
    Generate -> Review [label="success"];
    Generate -> Generate [label="retry", loop_restart=true];
    Review -> Done [label="[A]pprove"];
    Review -> Generate [label="[R]etry"];
}
