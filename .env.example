# ============================================================
# Attractor - Environment Configuration (LiteLLM Only)
# ============================================================
# Copy this file to .env and fill in the values.
# The .env file is auto-loaded when the LLM client initializes.
# ============================================================

# ----------------------------------------------------------
# LiteLLM core configuration
# ----------------------------------------------------------
# Model is required unless your code always passes Request.model explicitly.
LITELLM_MODEL=provider/model-name

# Use this when routing directly with provider credentials.
# LITELLM_API_KEY=your-provider-or-proxy-key-here

# Optional LiteLLM Proxy / OpenAI-compatible gateway URL.
# LITELLM_BASE_URL=http://localhost:4000

# Optional override if you register custom providers in code.
# DEFAULT_LLM_PROVIDER=litellm

# Optional fallback used by pipeline nodes.
# DEFAULT_LLM_MODEL=provider/model-name
